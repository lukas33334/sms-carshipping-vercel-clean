{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/media/:path*",
      "destination": "/api/media/:path*"
    },
    {
      "source": "/tracking",
      "destination": "/index.html"
    },
    {
      "source": "/calculator",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/impressum",
      "destination": "/index.html"
    },
    {
      "source": "/404",
      "destination": "/index.html"
    }
  ]
}
